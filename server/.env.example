PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/stride
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Production notes:
# - If Express serves the built React app, you can omit CLIENT_URL (same-origin).
# - If your frontend is deployed separately, set CLIENT_URL to its public URL.
